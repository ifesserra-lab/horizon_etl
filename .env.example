# SigPesq Credentials
SIGPESQ_USERNAME=your_username_here
SIGPESQ_PASSWORD=your_password_here

# Database
DATABASE_URL=sqlite:///db/horizon.db
STORAGE_TYPE=db
JSON_DATA_DIR=./data_json

# Prefect
# Local (non-Docker): http://127.0.0.1:4200/api
# Docker Compose: overridden to http://server:4200/api by docker-compose.yml
PREFECT_API_URL=http://127.0.0.1:4200/api

# Telegram notifications (optional — leave blank to disable)
HORIZON_TELEGRAM_BOT_TOKEN=your_bot_token_here
HORIZON_TELEGRAM_CHAT_ID=your_group_chat_id_here

# Browser paths for Lattes/SigPesq (set automatically in Docker; override for local if needed)
# Docker values: CHROME_BINARY=/usr/bin/chromium  CHROMEDRIVER_PATH=/usr/bin/chromedriver
CHROME_BINARY=
CHROMEDRIVER_PATH=
