# SigPesq Credentials
SIGPESQ_USERNAME=your_username_here
SIGPESQ_PASSWORD=your_password_here
DATABASE_URL=postgresql://supabase:pass@localhost:5432/postgres
STORAGE_TYPE=db
JSON_DATA_DIR=./data_json

# Prefect Configuration
# For local Docker setup: http://127.0.0.1:4200/api
PREFECT_API_URL=http://127.0.0.1:4200/api

# Telegram notifications
# Configure the Horizon Messages group chat id. Group names are not accepted by
# the Bot API; add the bot to the group and use the numeric chat id.
HORIZON_TELEGRAM_BOT_TOKEN=your_bot_token_here
HORIZON_TELEGRAM_CHAT_ID=your_group_chat_id_here
